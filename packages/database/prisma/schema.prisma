// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TradeSide {
  BUY
  SELL
}

enum MarketType {
  SPOT
  PERP
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderPosition {
  LONG
  SHORT
}

enum OrderStatus {
  OPEN
  PARTIAL_FILLED
  PARTIAL_REJECTED
  FILLED
  CANCELLED
  REJECTED
}

enum FillStatus {
  TRADE
  STP
}

enum STPMode {
  CANCEL_MAKER
  CANCEL_TAKER
  CANCEL_BOTH
}

enum TimeInForce {
  GTC
  IOC
  FOK
}

enum AssetTransactionType {
  ON_RAMP
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
}

enum AssetTransactionStatus {
  PENDING
  APPLIED
  REJECTED
  CANCELLED
}

model User {
  id                         String             @id @default(cuid())
  username                   String             @unique
  email                      String             @unique
  passwordHash               String
  isVerified                 Boolean            @default(false)
  isArchived                 Boolean            @default(false)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  sessions                   Session[]
  orders                     Order[]
  makerTrades                Trade[]            @relation("MakerUserTrades")
  takerTrades                Trade[]            @relation("TakerUserTrades")
  assetTransactions          AssetTransaction[]
  fundingPayments            FundingPayment[]
  paidLiquidationAttempts    LiquidationEvent[] @relation("LiquidatedUserEvents")
  initiatedLiquidationEvents LiquidationEvent[] @relation("LiquidatorUserEvents")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(references: [id], fields: [userId])
  refreshTokenHash String
  deviceIP         String
  userAgent        String
  revoke           Boolean   @default(false)
  revokeAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Market {
  id                 String               @id
  name               String               @unique
  marketType         MarketType           @default(SPOT)
  baseAssetId        String
  quoteAssetId       String
  baseAsset          Asset                @relation("BaseAsset", fields: [baseAssetId], references: [id])
  quoteAsset         Asset                @relation("QuoteAsset", fields: [quoteAssetId], references: [id])
  maxLeverage        Int                  @default(1)
  minQty             String
  tickSize           String
  lotSize            String
  minNotional        String
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  orders             Order[]
  trades             Trade[]
  ticker             MarketTicker?
  tickerCandles      MarketTickerCandle[]
  fundingSettlements FundingSettlement[]
  fundingPayments    FundingPayment[]
  liquidationEvents  LiquidationEvent[]

  @@unique([baseAssetId, quoteAssetId, marketType])
  @@index([name])
  @@index([marketType, active])
}

model Asset {
  id                String             @id @default(cuid())
  name              String?
  symbol            String             @unique
  logo              String?
  precision         Int
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  baseMarkets       Market[]           @relation("BaseAsset")
  quoteMarkets      Market[]           @relation("QuoteAsset")
  assetTransactions AssetTransaction[]

  @@index([symbol])
}

model Order {
  id                String             @id @default(cuid())
  sequence          BigInt             @unique @default(autoincrement())
  userId            String
  marketId          String
  marketType        MarketType
  type              OrderType
  side              TradeSide
  position          OrderPosition?
  status            OrderStatus
  entryPrice        String
  quantity          String
  filledQuantity    String             @default("0")
  remainingQuantity String
  averagePrice      String             @default("0")
  postOnly          Boolean            @default(false)
  reduceOnly        Boolean            @default(false)
  liquidation       Boolean            @default(false)
  leverage          Int?
  margin            String?
  stpMode           STPMode            @default(CANCEL_TAKER)
  timeInForce       TimeInForce        @default(GTC)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  cancelledAt       DateTime?
  filledAt          DateTime?
  user              User               @relation(fields: [userId], references: [id])
  market            Market             @relation(fields: [marketId], references: [id])
  makerTrades       Trade[]            @relation("MakerOrderTrades")
  takerTrades       Trade[]            @relation("TakerOrderTrades")
  liquidationEvents LiquidationEvent[]

  @@index([marketId])
  @@index([userId])
  @@index([userId, marketId])
  @@index([status, marketId])
  @@index([createdAt])
}

model Trade {
  id            String     @id @default(cuid())
  engineTradeId BigInt?
  marketId      String
  price         String
  quantity      String
  side          TradeSide
  status        FillStatus @default(TRADE)
  makerOrderId  String
  takerOrderId  String
  makerUserId   String
  takerUserId   String
  makerFee      String     @default("0")
  takerFee      String     @default("0")
  makerOrder    Order      @relation("MakerOrderTrades", fields: [makerOrderId], references: [id])
  takerOrder    Order      @relation("TakerOrderTrades", fields: [takerOrderId], references: [id])
  makerUser     User       @relation("MakerUserTrades", fields: [makerUserId], references: [id])
  takerUser     User       @relation("TakerUserTrades", fields: [takerUserId], references: [id])
  market        Market     @relation(fields: [marketId], references: [id])
  createdAt     DateTime   @default(now())

  @@unique([marketId, engineTradeId])
  @@index([marketId, createdAt])
  @@index([makerOrderId])
  @@index([takerOrderId])
  @@index([makerUserId])
  @@index([takerUserId])
}

model MarketTicker {
  marketId              String   @id
  lastPrice             String
  priceChange24h        String   @default("0")
  priceChangePercent24h String   @default("0")
  high24h               String
  low24h                String
  volume24h             String   @default("0")
  quoteVolume24h        String   @default("0")
  lastTradeId           BigInt?
  updatedAt             DateTime @updatedAt
  market                Market   @relation(fields: [marketId], references: [id])

  @@index([updatedAt])
}

model MarketTickerCandle {
  marketId    String
  interval    String
  bucketStart DateTime
  open        String
  high        String
  low         String
  close       String
  volume      String   @default("0")
  quoteVolume String   @default("0")
  tradeCount  Int      @default(0)
  lastTradeId BigInt?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  market      Market   @relation(fields: [marketId], references: [id])

  @@id([marketId, interval, bucketStart])
  @@index([marketId, interval, bucketStart])
}

model AssetTransaction {
  id          String                 @id @default(cuid())
  userId      String
  assetId     String
  type        AssetTransactionType
  status      AssetTransactionStatus @default(PENDING)
  amount      String
  referenceId String?
  reason      String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  appliedAt   DateTime?
  user        User                   @relation(fields: [userId], references: [id])
  asset       Asset                  @relation(fields: [assetId], references: [id])

  @@index([userId, createdAt])
  @@index([assetId, createdAt])
  @@index([type, status])
}

model FundingSettlement {
  id              String           @id @default(cuid())
  marketId        String
  indexPrice      String
  markPrice       String
  intervalSeconds Int
  fundingRateBps  String
  insuranceUsed   String           @default("0")
  paymentsCount   Int              @default(0)
  settledAt       DateTime         @default(now())
  market          Market           @relation(fields: [marketId], references: [id])
  payments        FundingPayment[]

  @@index([marketId, settledAt])
}

model FundingPayment {
  id                String             @id @default(cuid())
  settlementId      String?
  marketId          String
  userId            String
  positionId        String
  amount            String
  fundingRateBps    String
  createdAt         DateTime           @default(now())
  fundingSettlement FundingSettlement? @relation(fields: [settlementId], references: [id])
  market            Market             @relation(fields: [marketId], references: [id])
  user              User               @relation(fields: [userId], references: [id])

  @@index([settlementId])
  @@index([marketId, createdAt])
  @@index([userId, createdAt])
  @@index([positionId])
}

model LiquidationEvent {
  id                 String   @id @default(cuid())
  marketId           String
  liquidatedUserId   String
  liquidatorUserId   String?
  liquidationOrderId String?
  indexPrice         String
  quantity           String
  bankruptcyPrice    String?
  liquidationPrice   String?
  insuranceUsed      String   @default("0")
  createdAt          DateTime @default(now())
  market             Market   @relation(fields: [marketId], references: [id])
  liquidatedUser     User     @relation("LiquidatedUserEvents", fields: [liquidatedUserId], references: [id])
  liquidatorUser     User?    @relation("LiquidatorUserEvents", fields: [liquidatorUserId], references: [id])
  liquidationOrder   Order?   @relation(fields: [liquidationOrderId], references: [id])

  @@index([marketId, createdAt])
  @@index([liquidatedUserId, createdAt])
  @@index([liquidatorUserId, createdAt])
  @@index([liquidationOrderId])
}

// Positions, user balances, and live orderbook levels are intentionally not
// modeled here. They are runtime trading-engine state and should not be stored
// as Postgres source-of-truth tables.
